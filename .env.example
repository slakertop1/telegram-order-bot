# Токен бота от @BotFather
BOT_TOKEN=123456789:AAE_your_token_here

# Telegram ID администраторов через запятую (узнать свой: @userinfobot)
ADMIN_IDS=123456789

# --- Оплата аванса (два режима) ---
# Режим 1 (по умолчанию): Telegram Stars — работает сразу, без настройки.
#   DEPOSIT_STARS — размер аванса в звёздах (0 = кнопка оплаты отключена).
#   STARS_AUTO_REFUND=1 — демо-режим: звёзды возвращаются плательщику сразу.
DEPOSIT_STARS=1
STARS_AUTO_REFUND=1

# Режим 2: оплата в рублях через провайдера из @BotFather -> /mybots -> Payments
# (ЮKassa, Robokassa и т.д. — список зависит от страны аккаунта).
# Если задать токен провайдера, он используется вместо Stars.
PAYMENT_PROVIDER_TOKEN=
DEPOSIT_RUB=500

# Путь к файлу базы SQLite
DB_PATH=data/bot.db
